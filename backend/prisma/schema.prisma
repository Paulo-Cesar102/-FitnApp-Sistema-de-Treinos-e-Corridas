generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Sex {
  M
  F
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  sex       Sex      @default(M)
  level     Int      @default(1)
  xp        Int      @default(0)
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  workouts           UserWorkout[]
  completedWorkouts  CompletedWorkout[]
  badges             UserBadge[]
  feedbacks          Feedback[]
  exercises          Exercise[]
}

model Category {
  id        String   @id @default(uuid())
  name      String

  exercises Exercise[]
}

model Exercise {
  id          String   @id @default(uuid())
  name        String
  description String?

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  primaryMuscleId String
  primaryMuscle   MuscleGroup @relation("PrimaryMuscle", fields: [primaryMuscleId], references: [id])

  secondaryMuscles ExerciseMuscle[]

  userId      String?
  user        User? @relation(fields: [userId], references: [id])

  workoutExercises UserWorkoutExercise[]
}
model WorkoutSet {
  id String @id @default(uuid())

  userId String
  exerciseId String

  reps Int
  weight Float

  createdAt DateTime @default(now())
}
model TrainingProgram {
  id          String   @id @default(uuid())
  name        String
  description String?

  durationWeeks Int

  createdAt DateTime @default(now())

  workouts ProgramWorkout[]
  
}

model ProgramWorkout {
  id String @id @default(uuid())

  programId String
  workoutId String

  week Int
  day  Int

  program TrainingProgram @relation(fields: [programId], references: [id])
  workout UserWorkout     @relation(fields: [workoutId], references: [id])
}

model MuscleGroup {
  id   String @id @default(uuid())
  name String @unique

  primaryExercises   Exercise[] @relation("PrimaryMuscle")
  secondaryExercises ExerciseMuscle[]
}
model ExerciseMuscle {
  id        String @id @default(uuid())

  exerciseId String
  muscleId   String

  exercise Exercise @relation(fields: [exerciseId], references: [id])
  muscle   MuscleGroup @relation(fields: [muscleId], references: [id])
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model UserWorkout {
  id         String   @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  exercises  UserWorkoutExercise[]

  completedWorkouts CompletedWorkout[]

  programWorkouts ProgramWorkout[]
}

model UserWorkoutExercise {
  id             String @id @default(uuid())

  userWorkoutId  String
  exerciseId     String

  sets           Int
  reps           Int

  userWorkout UserWorkout @relation(fields: [userWorkoutId], references: [id])
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([userWorkoutId, exerciseId])
}

model CompletedWorkout {
  id         String   @id @default(uuid())

  userId     String
  workoutId  String

  xpEarned   Int
  doneAt     DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  workout    UserWorkout @relation(fields: [workoutId], references: [id])
}

model Badge {
  id   String @id @default(uuid())
  name String

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())

  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User  @relation(fields: [userId], references: [id])
  badge     Badge @relation(fields: [badgeId], references: [id])
}

model Feedback {
  id        String   @id @default(uuid())

  userId    String
  message   String
  rating    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}