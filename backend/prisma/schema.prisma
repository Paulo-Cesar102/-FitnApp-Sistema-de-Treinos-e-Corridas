// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  level     Int      @default(1)
  xp        Int      @default(0)
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  completedWorkouts CompletedWorkout[]
  badges             UserBadge[]
  feedbacks          Feedback[]

  workouts           UserWorkout[]
}

model Workout {
  id    String @id @default(uuid())
  name  String

  completedBy CompletedWorkout[]
}

model CompletedWorkout {
  id        String   @id @default(uuid())
  userId    String
  workoutId String
  doneAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  workout Workout @relation(fields: [workoutId], references: [id])
}

model Badge {
  id   String @id @default(uuid())
  name String

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  message   String
  rating    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
model Category {
  id        String     @id @default(uuid())
  name      String

  exercises Exercise[]
  workouts  UserWorkout[]
}

model Exercise {
  id          String   @id @default(uuid())
  name        String
  description String?

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  workoutExercises UserWorkoutExercise[]
}

model UserWorkout {
  id         String   @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  exercises  UserWorkoutExercise[]
}

model UserWorkoutExercise {
  id             String @id @default(uuid())

  userWorkoutId  String
  exerciseId     String

  sets           Int
  reps           Int

  userWorkout UserWorkout @relation(fields: [userWorkoutId], references: [id])
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([userWorkoutId, exerciseId])
}
